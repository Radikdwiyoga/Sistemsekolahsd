# PostgreSQL (Aiven) — dipakai oleh api/db/pgClient.ts, server.ts, dan scripts/migrate-seed.ts
PGHOST=
PGPORT=
PGUSER=
PGPASSWORD=
PGDATABASE=

# Set ke 'true' supaya `npm run dev` di lokal juga terhubung ke database Aiven asli
# (lewat /api/db/sync dan /api/db/update), bukan cuma localStorage browser.
# TANPA ini, testing lokal tidak pernah menyentuh database sungguhan.
VITE_USE_API=true
